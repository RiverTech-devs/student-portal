{
  "rules": {
    "arcade": {

      "players": {
        "$supabase_uid": {
          ".read": true,
          ".write": "auth != null && auth.uid == $supabase_uid"
        }
      },

      "friends": {
        "$supabase_uid": {
          ".read": "auth != null",
          ".write": "auth != null && auth.uid == $supabase_uid",
          "list": {
            "$friend_id": {
              ".write": "auth != null && (auth.uid == $supabase_uid || auth.uid == $friend_id)"
            }
          },
          "requests": {
            "incoming": {
              "$from_id": {
                ".write": "auth != null && auth.uid == $from_id"
              }
            },
            "outgoing": {
              "$to_id": {
                ".write": "auth != null && auth.uid == $supabase_uid"
              }
            }
          },
          "invites": {
            "$invite_id": {
              ".write": "auth != null"
            }
          }
        }
      },

      "games": {
        "$game_id": {
          "collections": {
            "$supabase_uid": {
              ".read": "auth != null",
              ".write": "auth != null && auth.uid == $supabase_uid"
            }
          },
          "decks": {
            "$supabase_uid": {
              ".read": true,
              ".write": "auth != null && auth.uid == $supabase_uid"
            }
          },
          "stats": {
            "$supabase_uid": {
              ".read": true,
              ".write": "auth != null && auth.uid == $supabase_uid"
            }
          }
        }
      },

      "matchmaking": {
        "$game_id": {
          "queue": {
            ".read": true,
            ".write": "auth != null"
          },
          "lobbies": {
            "$lobby_id": {
              ".read": true,
              ".write": "auth != null"
            }
          }
        }
      },

      "matches": {
        "$game_id": {
          "$match_id": {
            ".read": true,
            ".write": "auth != null && (data.child('players/1/supabase_user_id').val() == auth.uid || data.child('players/2/supabase_user_id').val() == auth.uid || !data.exists())"
          }
        }
      },

      "spectating": {
        "$match_id": {
          ".read": true,
          "spectators": {
            "$supabase_uid": {
              ".read": true,
              ".write": "auth != null && auth.uid == $supabase_uid"
            }
          }
        }
      },

      "leaderboards": {
        "$game_id": {
          ".read": true,
          ".write": false
        }
      }
    }
  }
}
